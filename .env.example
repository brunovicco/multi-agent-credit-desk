APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
SERVICE_NAME=multi-agent-credit-desk

# Reserved, inactive: Langfuse tracing variable names (see docs/LLM_OBSERVABILITY.md).
# No tracing adapter is implemented in this repository yet; these names are recorded now so a
# future implementation (planned in the sibling a2a-otel-kit library) follows this contract from
# the first line of code. Setting them today has no effect.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_CAPTURE_CONTENT=false
